#!/bin/sh
# sput — Sputter CLI launcher (SPEC §9).
# Prefer the M7 saved core when present; otherwise fall back to the portable
# M0 `sbcl --script` path.
SPUTTER_ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
export SPUTTER_ROOT
SPUTTER_IMAGE="$SPUTTER_ROOT/bin/sput.image"
if [ -f "$SPUTTER_IMAGE" ]; then
  # --noinform: the host banner must never reach a user channel (I2)
  exec sbcl --core "$SPUTTER_IMAGE" --noinform -- "$@"
fi
exec sbcl --script "$SPUTTER_ROOT/src/boot.lisp" "$@"
