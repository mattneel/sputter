fn classify(n) {
    let inner = {
        let t = n * n;
        t + 1
    };

    let side = if n < 0 { -1 } else if n == 0 { 0 } else { 1 };

    var count = 0;
    while count < inner { count += 1; }

    let apply = fn(f, x) { f(x) };

    if side == 0 { return "zero"; }

    apply(fn(x) { x + side }, count)
}

fn never() f64 {
    unreachable
}
